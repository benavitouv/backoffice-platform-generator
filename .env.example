# ── Claude AI ──
# Your Anthropic API key (from https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-...

# ── GitHub ──
# Personal access token with 'repo' scope
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_...
# GitHub username or org where new repos will be created
GITHUB_OWNER=your-github-username

# ── Vercel ──
# Personal access token (from https://vercel.com/account/tokens)
VERCEL_TOKEN=...
# Team ID if deploying to a Vercel team (optional, leave blank for personal)
VERCEL_TEAM_ID=

# ── Template env vars (injected into each generated Vercel project) ──
# These are the Wonderful AI webhook and storage credentials
TEMPLATE_WEBHOOK_URL=https://api.demo.wonderful.ai/api/v1/tasks/webhook/...
TEMPLATE_WEBHOOK_SECRET=...
TEMPLATE_STORAGE_URL=https://api.demo.wonderful.ai/api/v1/storage
TEMPLATE_STORAGE_API_KEY=...
TEMPLATE_TASK_TYPE=process_application
TEMPLATE_TRIGGER_ID=...

# ── Server (optional) ──
PORT=5173
