# ── Claude AI ──
# Your Anthropic API key (from https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-...

# ── GitHub ──
# Personal access token with 'repo' scope
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_...
# GitHub username or org where new repos will be created
GITHUB_OWNER=your-github-username

# ── Vercel ──
# Personal access token (from https://vercel.com/account/tokens)
VERCEL_TOKEN=...
# Team ID if deploying to a Vercel team (optional, leave blank for personal)
VERCEL_TEAM_ID=

# ── Template env vars (injected into each generated Vercel project) ──
# Each template type has its own Wonderful AI webhook and storage credentials.
# These are injected into every new customer site that uses that template.

# Health Fund Referral (form17)
FORM17_WEBHOOK_URL=https://api.demo.wonderful.ai/api/v1/tasks/webhook/...
FORM17_WEBHOOK_SECRET=...
FORM17_STORAGE_URL=https://api.demo.wonderful.ai/api/v1/storage
FORM17_STORAGE_API_KEY=...
FORM17_TASK_TYPE=process_application
FORM17_TRIGGER_ID=...

# Health Insurance (insurance)
INSURANCE_WEBHOOK_URL=https://api.demo.wonderful.ai/api/v1/tasks/webhook/...
INSURANCE_WEBHOOK_SECRET=...
INSURANCE_STORAGE_URL=https://api.demo.wonderful.ai/api/v1/storage
INSURANCE_STORAGE_API_KEY=...
INSURANCE_TASK_TYPE=process_application
INSURANCE_TRIGGER_ID=...

# Bank Loan (loan)
LOAN_WEBHOOK_URL=https://api.demo.wonderful.ai/api/v1/tasks/webhook/...
LOAN_WEBHOOK_SECRET=...
LOAN_STORAGE_URL=https://api.demo.wonderful.ai/api/v1/storage
LOAN_STORAGE_API_KEY=...
LOAN_TASK_TYPE=process_application
LOAN_TRIGGER_ID=...

# ── Server (optional) ──
PORT=5173
